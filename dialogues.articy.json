        { "Type": "DialogueFragment", "Properties": { "Id": "0x0100000000000301", "TechnicalName": "Dlg_Czech_root", "Parent": "0x0100000000000300", "Speaker": "0x0100000000010001", "DisplayName": "", "Text": "'Odkud jste?' She smiles at you, her eyes moons blinking in the strobes.", "MenuText": "", "InputPins": [{ "Id": "0x0100000000003100", "Owner": "0x0100000000000301", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000003101", "Owner": "0x0100000000000301", "Text": "", "Connections": [{ "Label": "", "Target": "0x0100000000000302", "TargetPin": "0x0100000000003200" }, { "Label": "", "Target": "0x0100000000000303", "TargetPin": "0x0100000000003300" }] }] } },
