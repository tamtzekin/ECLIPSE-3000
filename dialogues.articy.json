        {
          "Type": "DialogueFragment",
          "Properties": { "Id": "0x0100000000000201", "TechnicalName": "Dlg_Music_root", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010001", "DisplayName": "", "Text": "Isn't this amazing?", "MenuText": "",
            "InputPins": [{ "Id": "0x0100000000002100", "Owner": "0x0100000000000201", "Text": "", "Connections": [] }],
            "OutputPins": [{ "Id": "0x0100000000002101", "Owner": "0x0100000000000201", "Text": "", "Connections": [
