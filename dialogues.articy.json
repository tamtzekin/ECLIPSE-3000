        },
        { "Type": "DialogueFragment", "Properties": { "Id": "0x0100000000000202", "TechnicalName": "Dlg_Music_c1", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010000", "DisplayName": "", "MenuText": "'I love it. I love you.'", "Text": "", "InputPins": [{ "Id": "0x0100000000002200", "Owner": "0x0100000000000202", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000002201", "Owner": "0x0100000000000202", "Text": "", "Connections": [{ "Label": "", "Target": "0x0100000000000204", "TargetPin": "0x0100000000002400" }] }] } },
        { "Type": "DialogueFragment", "Properties": { "Id": "0x0100000000000203", "TechnicalName": "Dlg_Music_c2", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010000", "DisplayName": "", "MenuText": "'It's normal. I come every week.'", "Text": "", "InputPins": [{ "Id": "0x0100000000002300", "Owner": "0x0100000000000203", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000002301", "Owner": "0x0100000000000203", "Text": "", "Connections": [{ "Label": "", "Target": "0x0100000000000205", "TargetPin": "0x0100000000002500" }] }] } },
        { "Type": "DialogueFragment", "Properties": { "Id": "0x0100000000000204", "TechnicalName": "Dlg_Music_b1", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010001", "DisplayName": "", "Text": "She blushes. 'Do you? I love trance. I love it. Angel voice. God whispers in the power. The sting is a signal from heaven.", "MenuText": "", "InputPins": [{ "Id": "0x0100000000002400", "Owner": "0x0100000000000204", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000002401", "Owner": "0x0100000000000204", "Text": "", "Connections": [{ "Label": "", "Target": "0x0100000000000206", "TargetPin": "0x0100000000002600" }] }] } },
        { "Type": "DialogueFragment", "Properties": { "Id": "0x0100000000000205", "TechnicalName": "Dlg_Music_b2", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010001", "DisplayName": "", "Text": "'Oh.' Disappointed, maybe? Did you upset her? Listen, you're in the club. Loosen up. Try to make friends. Don't be so lonely.", "MenuText": "", "InputPins": [{ "Id": "0x0100000000002500", "Owner": "0x0100000000000205", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000002501", "Owner": "0x0100000000000205", "Text": "", "Connections": [{ "Label": "", "Target": "0x0100000000000207", "TargetPin": "0x0100000000002700" }, { "Label": "", "Target": "0x0100000000000208", "TargetPin": "0x0100000000002800" }] }] } },
        { "Type": "DialogueFragment", "Properties": { "Id": "0x0100000000000206", "TechnicalName": "Dlg_Music_b1_end", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010000", "DisplayName": "", "MenuText": "[Leave]", "Text": "", "InputPins": [{ "Id": "0x0100000000002600", "Owner": "0x0100000000000206", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000002601", "Owner": "0x0100000000000206", "Text": "", "Connections": [] }] } },
        { "Type": "DialogueFragment", "Properties": { "Id": "0x0100000000000207", "TechnicalName": "Dlg_Music_b2_c1", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010000", "DisplayName": "", "MenuText": "'Are you doing alright?'", "Text": "", "InputPins": [{ "Id": "0x0100000000002700", "Owner": "0x0100000000000207", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000002701", "Owner": "0x0100000000000207", "Text": "", "Connections": [{ "Label": "", "Target": "0x0100000000000209", "TargetPin": "0x0100000000002900" }] }] } },
        { "Type": "DialogueFragment", "Properties": { "Id": "0x0100000000000208", "TechnicalName": "Dlg_Music_b2_c2", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010000", "DisplayName": "", "MenuText": "'I feel it. I feel everything. The music is here with me.'", "Text": "", "InputPins": [{ "Id": "0x0100000000002800", "Owner": "0x0100000000000208", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000002801", "Owner": "0x0100000000000208", "Text": "", "Connections": [] }] } },
        { "Type": "DialogueFragment", "Properties": { "Id": "0x0100000000000209", "TechnicalName": "Dlg_Music_b3", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010001", "DisplayName": "", "Text": "She looks dead at you, wondering who you are, and all the stories you will take with you when you disappear, when you never see her again. 'I hid the rest of it behind the speakers. If you want some.' She pulls you in and kisses you. Her lips are bitter.", "MenuText": "", "InputPins": [{ "Id": "0x0100000000002900", "Owner": "0x0100000000000209", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000002901", "Owner": "0x0100000000000209", "Text": "", "Connections": [{ "Label": "", "Target": "0x010000000000020A", "TargetPin": "0x0100000000002A00" }] }] } },
        { "Type": "DialogueFragment", "Properties": { "Id": "0x010000000000020A", "TechnicalName": "Dlg_Music_b3_end", "Parent": "0x0100000000000200", "Speaker": "0x0100000000010000", "DisplayName": "", "MenuText": "[Leave]", "Text": "", "InputPins": [{ "Id": "0x0100000000002A00", "Owner": "0x010000000000020A", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000002A01", "Owner": "0x010000000000020A", "Text": "", "Connections": [] }] } },

