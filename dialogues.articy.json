        {
          "Type": "Dialogue",
          "Properties": { "Id": "0x0100000000000400", "TechnicalName": "Dlg_LostFriend1", "DisplayName": "Lost Friend", "Text": "Looking for a friend", "InputPins": [{ "Id": "0x0100000000004000", "Owner": "0x0100000000000400", "Text": "", "Connections": [] }], "OutputPins": [{ "Id": "0x0100000000004001", "Owner": "0x0100000000000400", "Text": "", "Connections": [{ "Label": "", "Target": "0x0100000000000401", "TargetPin": "0x0100000000004100" }] }] }
